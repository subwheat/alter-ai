# alter.ai v0.1 — Scaleway GPU Instance environment variables
# Copy to .env and fill in your values before launching.

# --- Node.js API Server ---
ALTER_AI_PORT=8080
ALTER_AI_MODEL_ID=google/gemma-4-E4B-it

# --- Python Gemma 4 Sidecar ---
ALTER_AI_MODEL_PATH=/mnt/blockstorage/alter-ai/models/google/gemma-4-E4B-it
ALTER_AI_DEVICE=auto
ALTER_AI_DTYPE=bfloat16

# Sidecar HTTP config (must match what the Node.js API server expects)
GEMMA_SIDECAR_URL=http://localhost:8090
GEMMA_SIDECAR_TIMEOUT_MS=120000
SIDECAR_PORT=8090

# --- Hugging Face ---
HF_HOME=/mnt/blockstorage/alter-ai/hf-home
HF_HUB_CACHE=/mnt/blockstorage/alter-ai/hf-cache

# --- Block storage logs ---
ALTER_AI_LOGS_DIR=/mnt/blockstorage/alter-ai/logs

# --- Database (optional, not required for core drug endpoint) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/alterai

# --- Session ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- Frontend ---
# Set to your Scaleway instance public IP or domain
# VITE_API_BASE_URL=http://your-instance-ip:8080
